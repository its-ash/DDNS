# Admin login password
ADMIN_PASSWORD=admin

# Base domain for DDNS hosts
BASE_DOMAIN=ash-api.online

# Database path
DATABASE_URL=sqlite:ddns.db

# Server binding
HOST=0.0.0.0
PORT=8181
DNS_PORT=53
# Session secret (change this to a random string)
SESSION_SECRET=this-is-a-very-long-secret-key-that-should-be-at-least-64-characters-long-for-security-purposes
